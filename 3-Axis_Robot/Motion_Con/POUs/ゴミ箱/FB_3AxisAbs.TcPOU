    <Property Name="bEnable" Id="{d0ee063c-29bb-4a0d-a052-69fa432f6f41}" FolderPath="GetState\">
      <Declaration><![CDATA[PROPERTY bEnable : BOOL]]></Declaration>
      <Get Name="Get" Id="{913c575c-8a9f-4e3d-9750-0d8f0e2fbb54}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[bEnable:=_bAxisEnable[E_Axis.X_Axis] AND _bAxisEnable[E_Axis.Y_Axis] AND _bAxisEnable[E_Axis.Z_Axis] AND _bAxisEnable[E_Axis.Gripper];]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="bError" Id="{ab62a505-7438-4fa7-b246-56db0abaeca9}" FolderPath="GetState\">
      <Declaration><![CDATA[PROPERTY bError : BOOL]]></Declaration>
      <Get Name="Get" Id="{482bc996-a415-42c3-9d51-2c6fbd676bc8}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[bError:=_bAxisError[E_Axis.X_Axis] or _bAxisError[E_Axis.Y_Axis] or _bAxisError[E_Axis.Z_Axis] or _bAxisError[E_Axis.Gripper];]]></ST>
        </Implementation>
      </Get>
    </Property>
