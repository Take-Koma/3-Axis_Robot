        </Implementation>
      </Get>
    </Property>
    <Property Name="bMoving" Id="{22ef7bf8-9104-4eee-b69b-3ba118a6f103}" FolderPath="GetState\">
      <Declaration><![CDATA[PROPERTY bMoving : BOOL]]></Declaration>
      <Get Name="Get" Id="{a5740c56-5f33-4c08-8942-759845c7ee85}">
