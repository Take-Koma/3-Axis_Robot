<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.11">
  <POU Name="FB_3AxisAbs" Id="{96c0f27a-7dc1-4352-9995-0ffba358f922}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_3AxisAbs
VAR_INPUT
END_VAR
VAR
	_bAxisError				:ARRAY[E_Axis.X_Axis..E_Axis.Gripper] OF BOOL;				//各軸Error
	nAxisErrorID			:ARRAY[E_Axis.X_Axis..E_Axis.Gripper] OF UDINT;				//各軸Error ID
	_bAxisMoving			:ARRAY[E_Axis.X_Axis..E_Axis.Gripper] OF BOOL;				//各軸moving
	_fAxisActPos			:ARRAY[E_Axis.X_Axis..E_Axis.Gripper] OF LREAL;				//各軸Actual Position
	
	_bAxisEnable			:ARRAY[E_Axis.X_Axis..E_Axis.Gripper] OF BOOL;				//各軸PoerON
	_bResetDone				:ARRAY[E_Axis.X_Axis..E_Axis.Gripper] OF BOOL;				//各軸リセット完了
	_bHaltDone				:ARRAY[E_Axis.X_Axis..E_Axis.Gripper] OF BOOL;				//各軸一時停止完了
	_bStopDone				:ARRAY[E_Axis.X_Axis..E_Axis.Gripper] OF BOOL;				//各軸停止完了





	

END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[//---なし---]]></ST>
    </Implementation>
    <Folder Name="GetState" Id="{1ecf3b7b-9174-412b-a010-f357b25b0168}" />
    <Method Name="AbsMove" Id="{3deffb0d-1398-4bdc-8eb4-b1e592b9a473}">
      <Declaration><![CDATA[METHOD AbsMove
VAR_INPUT
	eAxis			:E_Axis;
	bMove			:BOOL;
	fTargetPos		:LREAL;
	fTargetVelo		:LREAL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE eAxis OF
	E_Axis.X_Axis:
		fbXAxis.fTargetPosition:=fTargetPos;
		fbXAxis.fTargetVelocity:=fTargetVelo;
		fbXAxis.MoveAbsolute(bMove:=bMove);

	E_Axis.Y_Axis:
		fbYAxis.fTargetPosition:=fTargetPos;
		fbYAxis.fTargetVelocity:=fTargetVelo;
		fbYAxis.MoveAbsolute(bMove:=bMove);
	
	E_Axis.Z_Axis:
		fbZAxis.fTargetPosition:=fTargetPos;
		fbZAxis.fTargetVelocity:=fTargetVelo;
		fbZAxis.MoveAbsolute(bMove:=bMove);
		
	E_Axis.Gripper:
		fbGripper.fTargetPosition:=fTargetPos;
		fbGripper.fTargetVelocity:=fTargetVelo;
		fbGripper.MoveAbsolute(bMove:=bMove);
	
END_CASE]]></ST>
      </Implementation>
    </Method>
    <Method Name="bAxisError" Id="{f2bdfde1-bf1b-406d-8321-2da14790c152}" FolderPath="GetState\">
      <Declaration><![CDATA[METHOD bAxisError : BOOL
VAR_INPUT
	eAxis	:E_Axis;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[bAxisError:=_bAxisError[eAxis];]]></ST>
      </Implementation>
    </Method>
