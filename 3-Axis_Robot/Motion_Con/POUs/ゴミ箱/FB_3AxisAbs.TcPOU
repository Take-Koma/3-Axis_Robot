    <Method Name="Halt" Id="{b54adf64-ccd1-466d-bb7c-69ce3a73680e}">
      <Declaration><![CDATA[METHOD Halt
VAR_INPUT
	bHalt		: BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// =========================================================
// Halting axis

	fbXAxis.Halt(bDriveHalt:= bHalt);
	fbYAxis.Halt(bDriveHalt:= bHalt);
	fbZAxis.Halt(bDriveHalt:= bHalt);
	fbGripper.Halt(bDriveHalt:= bHalt);

	_bHaltDone[E_Axis.X_Axis]:=fbXAxis.bStateHaltDone;
	_bHaltDone[E_Axis.Y_Axis]:=fbYAxis.bStateHaltDone;
	_bHaltDone[E_Axis.Z_Axis]:=fbZAxis.bStateHaltDone;
	_bHaltDone[E_Axis.Gripper]:=fbGripper.bStateHaltDone;

// =========================================================]]></ST>
      </Implementation>
    </Method>
    <Method Name="Homing" Id="{6f106111-2f0f-4ae2-8cd5-adc130115872}">
      <Declaration><![CDATA[METHOD Homing: BOOL
VAR_INPUT
	bHome						:BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF bHome=TRUE THEN
	fbXAxis.fTargetPosition:=0;
	fbYAxis.fTargetPosition:=0;
	fbZAxis.fTargetPosition:=0;
	fbGripper.fTargetPosition:=0;
	
	fbXAxis.fTargetVelocity:=50;
	fbYAxis.fTargetVelocity:=50;
	fbZAxis.fTargetVelocity:=50;
	fbGripper.fTargetVelocity:=100;
END_IF

fbXAxis.MoveAbsolute(bMove:=bHome);
fbYAxis.MoveAbsolute(bMove:=bHome);
fbZAxis.MoveAbsolute(bMove:=bHome);
fbGripper.MoveAbsolute(bMove:=bHome);


IF bHome=TRUE AND bMoving=TRUE THEN
	Homing:=TRUE;
ELSIF bMoving=FALSE THEN
	Homing:=FALSE;
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="Jog" Id="{e7b8e2da-3d1c-4ca2-8d33-599ed5ce88f8}">
      <Declaration><![CDATA[METHOD Jog
VAR_INPUT
	eAxis			:E_Axis;
	bMove			:BOOL;
	fTargetPos		:LREAL;
	fTargetVelo		:LREAL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[//立下りエッジを取得	
fbJogFEdge[eAxis](CLK:=bMove,Q=>);

CASE eAxis OF
	E_Axis.X_Axis:
		fbXAxis.fTargetPosition:=fTargetPos;
		fbXAxis.fTargetVelocity:=fTargetVelo;
		fbXAxis.MoveAbsolute(bMove:=bMove);
		fbXAxis.Halt(bDriveHalt:=fbJogFEdge[eAxis].Q);

	E_Axis.Y_Axis:
		fbYAxis.fTargetPosition:=fTargetPos;
		fbYAxis.fTargetVelocity:=fTargetVelo;
		fbYAxis.MoveAbsolute(bMove:=bMove);
		fbYAxis.Halt(bDriveHalt:=fbJogFEdge[eAxis].Q);
	
	E_Axis.Z_Axis:
		fbZAxis.fTargetPosition:=fTargetPos;
		fbZAxis.fTargetVelocity:=fTargetVelo;
		fbZAxis.MoveAbsolute(bMove:=bMove);
		fbZAxis.Halt(bDriveHalt:=fbJogFEdge[eAxis].Q);
		
	E_Axis.Gripper:
		fbGripper.fTargetPosition:=fTargetPos;
		fbGripper.fTargetVelocity:=fTargetVelo;
		fbGripper.MoveAbsolute(bMove:=bMove);
		fbGripper.Halt(bDriveHalt:=fbJogFEdge[eAxis].Q);
	
END_CASE
]]></ST>
      </Implementation>
    </Method>
    <Method Name="Power" Id="{51b884c8-d2fc-4356-8911-012ebb2fd5ac}">
      <Declaration><![CDATA[METHOD Power
VAR_INPUT
	bAxisEnable				: BOOL;			// Enable of axis
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
	
	

	_bAxisError[E_Axis.X_Axis]	:=fbXAxis.bStateError;
	nAxisErrorID[E_Axis.X_Axis]	:=fbXAxis.nStateErrorID;
	_bAxisMoving[E_Axis.X_Axis]	:=fbXAxis.bStateMoving;
	_fAxisActPos[E_Axis.X_Axis]	:=fbXAxis.fStateActPos;

	
	
	_bAxisError[E_Axis.Y_Axis]	:=fbYAxis.bStateError;
	nAxisErrorID[E_Axis.Y_Axis]	:=fbYAxis.nStateErrorID;
	_bAxisMoving[E_Axis.Y_Axis]	:=fbYAxis.bStateMoving;
	_fAxisActPos[E_Axis.Y_Axis]	:=fbYAxis.fStateActPos;

	
		
	_bAxisError[E_Axis.Z_Axis]	:=fbZAxis.bStateError;
	nAxisErrorID[E_Axis.Z_Axis]	:=fbZAxis.nStateErrorID;
	_bAxisMoving[E_Axis.Z_Axis]	:=fbZAxis.bStateMoving;
	_fAxisActPos[E_Axis.Z_Axis]	:=fbZAxis.fStateActPos;
	
	
		
	_bAxisError[E_Axis.Gripper]	:=fbGripper.bStateError;
	nAxisErrorID[E_Axis.Gripper]:=fbGripper.nStateErrorID;
	_bAxisMoving[E_Axis.Gripper]:=fbGripper.bStateMoving;
	_fAxisActPos[E_Axis.Gripper]:=fbGripper.fStateActPos;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="Reset" Id="{564f71f6-fe7f-411c-a8cf-667aa59290fc}">
      <Declaration><![CDATA[METHOD Reset : BOOL
VAR_INPUT
	bReset		: BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// =========================================================
// Resetting axis

	fbXAxis.Reset(bDriveReset := bReset);
	fbYAxis.Reset(bDriveReset := bReset);
	fbZAxis.Reset(bDriveReset := bReset);
	fbGripper.Reset(bDriveReset := bReset);
	
	_bResetDone[E_Axis.X_Axis]:=fbXAxis.bStateResetDone;
	_bResetDone[E_Axis.Y_Axis]:=fbYAxis.bStateResetDone;
	_bResetDone[E_Axis.Z_Axis]:=fbZAxis.bStateResetDone;
	_bResetDone[E_Axis.Gripper]:=fbGripper.bStateResetDone;

// =========================================================]]></ST>
      </Implementation>
    </Method>
    <Method Name="Stop" Id="{df408de1-c41d-49e9-a76d-f6660668daa7}">
      <Declaration><![CDATA[METHOD Stop
VAR_INPUT
	bStop		: BOOL;	
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// =========================================================
// Stopping axis

	fbXAxis.Stop(bDriveStop := bStop);
	fbYAxis.Stop(bDriveStop := bStop);
	fbZAxis.Stop(bDriveStop := bStop);
	fbGripper.Stop(bDriveStop := bStop);
	
	_bStopDone[E_Axis.X_Axis]:=fbXAxis.bStateStopDone;
	_bStopDone[E_Axis.Y_Axis]:=fbYAxis.bStateStopDone;
	_bStopDone[E_Axis.Z_Axis]:=fbZAxis.bStateStopDone;
	_bStopDone[E_Axis.Gripper]:=fbGripper.bStateStopDone;
		
// =========================================================]]></ST>
      </Implementation>
    </Method>
