        </Implementation>
      </Get>
    </Property>
    <Property Name="fTargetPosition" Id="{77146afd-a1df-4ddb-82da-373341e634e6}">
      <Declaration><![CDATA[PROPERTY fTargetPosition : LREAL]]></Declaration>
      <Get Name="Get" Id="{b639191e-3a45-47e0-9665-affaec67bafa}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[fTargetPosition:=_fTargetPosition;]]></ST>
        </Implementation>
      </Get>
      <Set Name="Set" Id="{60b0eb9f-25a0-4f88-8ef9-938c0a2f5a1f}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[_fTargetPosition:=LIMIT(_fMinPosition,fTargetPosition,_fMaxPosition);]]></ST>
        </Implementation>
      </Set>
    </Property>
    <Property Name="fTargetVelocity" Id="{072eee44-9a89-46ff-9c6c-081e21838b82}">
      <Declaration><![CDATA[PROPERTY fTargetVelocity : LREAL]]></Declaration>
