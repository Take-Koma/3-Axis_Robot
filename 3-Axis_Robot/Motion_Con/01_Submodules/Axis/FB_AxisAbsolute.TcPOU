          <ST><![CDATA[fTargetVelocity := _fTargetVelocity;]]></ST>
        </Implementation>
      </Get>
      <Set Name="Set" Id="{70932f21-070c-4a8e-a2f5-0d6642329682}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[_fTargetVelocity :=LIMIT(_fMinVelocity ,fTargetVelocity,_fMaxVelocity);]]></ST>
        </Implementation>
      </Set>
    </Property>
    <Method Name="Halt" Id="{e88a2abb-6023-4065-9098-7fa187efe6ad}">
      <Declaration><![CDATA[METHOD Halt
VAR_INPUT
	bDriveHalt		: BOOL;					// Request stop
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// =========================================================

IF bDriveHalt THEN
	// Move Execute FALSE
	fbMCMove(	Execute	:= FALSE,
				Axis 	:= AxisRef);
ELSE
	// Reset done signal
	_bHaltDone := FALSE;
END_IF

// Trigger
fbTriggerHalt(CLK := bDriveHalt);

IF fbTriggerHalt.Q THEN
	fbMcHalt(	Execute	:= TRUE,
				Axis 	:= AxisRef);
ELSE
	fbMcHalt(Axis := AxisRef);
END_IF

// Done / Error / Command aborted
IF fbMcHalt.Done OR fbMcHalt.Error OR fbMcHalt.CommandAborted THEN
	_bStateError		:= fbMcHalt.Error;
	_nStateErrorID		:= fbMcHalt.ErrorID;
	_bHaltDone 			:= fbMcHalt.Done;
	
	fbMCMove(	Execute	:= FALSE,
				Axis 	:= AxisRef);
				
	fbMcHalt(	Execute	:= FALSE,
				Axis 	:= AxisRef);
END_IF

// =========================================================]]></ST>
      </Implementation>
    </Method>
    <Method Name="MoveAbsolute" Id="{16ab69b9-b24d-46b6-acf0-f1ab70404dae}">
      <Declaration><![CDATA[METHOD MoveAbsolute
VAR_INPUT
	bMove		:REFERENCE TO BOOL; 
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// =========================================================

IF bMove=TRUE AND(fbMCMove.Error=FALSE OR fbMcHalt.Execute=FALSE OR fbMcStop.Execute=FALSE) THEN
	fbMCMove(	Execute 		:=TRUE,
				Position		:=_fTargetPosition,
				Velocity 		:= _fTargetVelocity,
				Axis 			:= AxisRef,
				Done			=>_bMoveDone,
				CommandAborted	=>_bMoveCommandAborted);	
ELSE
	fbMCMove(	Axis 			:= AxisRef);	
END_IF

// Error / Command aborted
IF fbMCMove.Done OR fbMCMove.Error OR fbMCMove.CommandAborted THEN
	IF fbMcMove.Error THEN
		_bStateError		:= TRUE;
		_nStateErrorID		:= fbMCMove.ErrorID;
	END_IF
	
	bMove:=FALSE;
	
	fbMCMove(	Execute 	:=FALSE,
				Axis 		:= AxisRef);
END_IF

IF fbMcStop.Execute=TRUE OR fbMcHalt.Execute=TRUE THEN
	bMove:=FALSE;
END_IF]]></ST>
      </Implementation>
    </Method>
    <Property Name="nStateErrorID" Id="{393e9573-61b8-4020-8aeb-991444f3a449}">
      <Declaration><![CDATA[PROPERTY nStateErrorID : UDINT]]></Declaration>
      <Get Name="Get" Id="{c1f8ed2c-525f-48c1-8881-05e641af6bd6}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[nStateErrorID:=_nStateErrorID;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Method Name="Reset" Id="{ea6409fe-eb80-4f4d-b54a-780889e04b6e}">
      <Declaration><![CDATA[METHOD Reset
VAR_INPUT
	bDriveReset		: BOOL;					// Request reset
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// =========================================================

IF NOT bDriveReset THEN
	_bResetDone 	:= FALSE;
END_IF

// Trigger
fbTriggerReset(CLK := bDriveReset);

IF fbTriggerReset.Q THEN
	_bResetDone		:= FALSE;
	
	fbMcReset(Execute := TRUE, Axis := AxisRef);
ELSE
	fbMcReset(Axis := AxisRef);
END_IF

// Done / Error
IF fbMcReset.Done OR fbMcReset.Error THEN
	_bStateError		:= fbMcReset.Error;
	_nStateErrorID		:= fbMcReset.ErrorID;
	_bResetDone 		:= fbMcReset.Done;

	fbMcReset(	Execute	:= FALSE,
				Axis 	:= AxisRef);
END_IF

// =========================================================]]></ST>
      </Implementation>
    </Method>
    <Method Name="Stop" Id="{befb5a74-67aa-4deb-96cf-8551f6226c61}">
      <Declaration><![CDATA[METHOD Stop
VAR_INPUT
	bDriveStop		: BOOL;					// Request stop
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// =========================================================

IF bDriveStop THEN
	// Move Execute FALSE
	fbMCMove(	Execute	:= FALSE,
				Axis 	:= AxisRef);
ELSE
	// Reset done signal
	_bStopDone := FALSE;
END_IF

// Trigger
fbTriggerStop(CLK := bDriveStop);

IF fbTriggerStop.Q THEN
	fbMcStop(	Execute	:= TRUE,
				Axis 	:= AxisRef);
ELSE
	fbMcStop(Axis := AxisRef);
END_IF

// Done / Error / Command aborted
IF fbMcStop.Done OR fbMcStop.Error OR fbMcStop.CommandAborted THEN
	_bStateError		:= fbMcStop.Error;
	_nStateErrorID 		:= fbMcStop.ErrorID;
	_bStopDone 			:= fbMcStop.Done;
	
	fbMCMove(	Execute	:= FALSE,
				Axis 	:= AxisRef);
				
	fbMcStop(	Execute	:= FALSE,
				Axis 	:= AxisRef);
END_IF

// =========================================================]]></ST>
      </Implementation>
    </Method>
