  <POU Name="FB_AxisAbsolute" Id="{13905c50-061e-47bd-88e1-faf6cd8ad728}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_AxisAbsolute
VAR	
	// =============== Done signals ============================
	_bResetDone			:BOOL;					// Status of function block MC_Reset
	_bHaltDone			:BOOL;					// Status of function block MC_Halt
	_bStopDone			:BOOL;					// Status of function block MC_Stop
	_bMoveDone			:BOOL;					// Status of function block MC_MoveAbsolute

	// =============== State variables ========================
	_bStatusEnable		:BOOL;					// Enable feedback
	_bStateError		:BOOL;					// Error signal
	_bMoveCommandAborted:BOOL;					// Status of function block MC_MoveAbsolute	
	_nStateErrorID		:UDINT;					// Error ID
	_bStateMoving		:BOOL;					// Status of moving
	_fStateActPos		:LREAL;					// Actual Position
	
	// =============== Position Velocity, override ============
	_fTargetPosition	:LREAL;					// Target Position 
	_fTargetVelocity	:LREAL;					// Target Velocity
	fOverride 			:LREAL := 100.0;		// Override 100%
	
	// =============== Axis Limit =============================
	_fMaxPosition		:LREAL;					//	MAX Target Position 
	_fMinPosition		:LREAL;					//	MIN Target Position 
	_fMaxVelocity		:LREAL;					//	MAX Target Velocity
	_fMinVelocity		:LREAL;					//	MIN Target Velocity
	
	// =============== Trigger function blocks ================
	fbTriggerReset		:R_TRIG;				// Trigger to recognize rising edge of reset input
	fbTriggerHalt		:R_TRIG;				// Trigger to recognize rising edge of halt input
	fbTriggerStop		:R_TRIG;				// Trigger to recognize rising edge of stop input
	fbTriggerMove		:R_TRIG;
	
	// =============== Axis reference =========================
	AxisRef				:AXIS_REF;				// Axis reference (process data plc/nc)
	
	// =============== Motion function blocks =================
	fbMcPower 			:MC_Power;				// FB for enable and override
	fbMcReset 			:MC_Reset;				// FB to reset axis
	fbMcStop 			:MC_Stop;				// FB to stop axis
	fbMcHalt			:MC_Halt;				// FB to halt axis
	fbMcMove			:MC_MoveAbsolute;		// FB to move axis (Absolute movement)
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[// =========================================================
;
// =========================================================]]></ST>
    </Implementation>
