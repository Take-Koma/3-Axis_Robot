      <LineId Id="1" Count="0" />
    </LineIds>
    <LineIds Name="FB_ZAxisAbsolute.MoveAbsolute">
      <LineId Id="1" Count="4" />
      <LineId Id="12" Count="1" />
      <LineId Id="6" Count="0" />
      <LineId Id="14" Count="0" />
      <LineId Id="7" Count="0" />
      <LineId Id="15" Count="1" />
