      <LineId Id="33" Count="0" />
      <LineId Id="14" Count="6" />
    </LineIds>
    <LineIds Name="FB_Alarm.FB_init">
      <LineId Id="1" Count="0" />
    </LineIds>
  </POU>
</TcPlcObject>